{
  "layer": "top",
  "position": "top",
  "modules-left": [
    "group/hardware",
    "network#speed",
    "wlr/taskbar",
  ],
  //"modules-center": ["hyprland/window"],
  "modules-right": [
    "tray",
    "pulseaudio",
    "pulseaudio#microphone",
    "network",
    "clock",
	"group/arch"
  ],
  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "´éó<span foreground='red'><sup>´Ĺä</sup></span>",
      "none": "´éó",
      "dnd-notification": "´çĚ<span foreground='red'><sup>´Ĺä</sup></span>",
      "dnd-none": "´çĚ",
      "inhibited-notification": "´éó<span foreground='red'><sup>´Ĺä</sup></span>",
      "inhibited-none": "´éó",
      "dnd-inhibited-notification": "´çĚ<span foreground='red'><sup>´Ĺä</sup></span>",
      "dnd-inhibited-none": "´çĚ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "network": {
    "format-wifi": "´çź {essid} ({signalStrength}%) ",
    "format-ethernet": "ˇ░Ź╣ {ifname}",
    "tooltip-format": "{ifname} via {gwaddr} ˇ░Ź╣",
    "format-linked": "{ifname} (No IP) ˇ░Ź╣",
    "format-disconnected": "Disconnected ÔÜá",
    "format-alt": "{ifname}: {ipaddr}/{cidr}",
	"on-click-right":"$HOME/.scripts/tog_network.sh"
  },
  "network#speed":{
    "format": "ÔćĹ{bandwidthUpBytes} Ôćô{bandwidthDownBytes}",
  },
  "battery": {
	    "on-scroll-up": "lightctl up ",
        "on-scroll-down": "lightctl down",
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "<span size='13000' foreground='#B1E3AD'>{icon}</span> {capacity}%",
    "format-warning": "<span size='13000' foreground='#B1E3AD'>{icon}</span> {capacity}%",
    "format-critical": "<span size='13000' foreground='#E38C8F'>{icon}</span> {capacity}%",
    "format-charging": "<span size='13000' foreground='#B1E3AD'>´çŽ </span>{capacity}%",
    "format-plugged": "<span size='13000' foreground='#B1E3AD'>´çŽ </span>{capacity}%",
    "format-alt": "<span size='13000' foreground='#B1E3AD'>{icon}</span> {time}",
    "format-full": "<span size='13000' foreground='#B1E3AD'>´ëÇ </span>{capacity}%",
    "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"],
    "tooltip-format": "{time}"
  },
  "temperature": {
    "critical-threshold": 80,
    "format": "{temperatureC}┬░C {icon}",
    "format-icons": ["´Łź", "´őë", "´Łę"]
  },
  "tray": {
    "icon-size": 20,
    "spacing": 10
  },
  "wlr/taskbar": {
    "all-outputs": true,
    "format": "{icon}",
    "icon-size": 18,
    "icon-theme": "Adwaita",
    "markup": true,
    "tooltip": true,
    "sort-by-app-id": true,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "on-click-right": "fullscreen",
    "rewrite": {},
    "ignore-list": [
      "rofi",
      "org.wezfurlong.wezterm",
      "DrClientLinux",
      "dwrg.exe",
	  "flameshot"
    ]
  },
  "clock": {
        "format": "{:ˇ▒Ž║ %I:%M %p ´ë│ %d/%m/%Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
	    "on-scroll-up": "lightctl up ",
        "on-scroll-down": "lightctl down"
  },
  "cpu": {
    "format": "{usage}% ´őŤ",
    "interval": 2,
    "tooltip": true
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "tooltip": false,
    "format-muted": "´ÇŽ Muted",
    "on-click": "pamixer -t",
    "on-scroll-up": "pamixer -i 5",
    "on-scroll-down": "pamixer -d 5",
    "scroll-step": 5,
    "format-icons": {
      "headphone": "´Çą",
      "hands-free": "´Çą",
      "headset": "´Çą",
      "phone": "´éĽ",
      "portable": "´éĽ",
      "car": "´ć╣",
      "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
    },
    "on-click-right": "pavucontrol -t 1",
    "on-click-middle": "$HOME/.scripts/rofi-bluetooth  & $HOME/.scripts/close_rofi_while_not_focus.sh "
  },
  "custom/pulseaudio": {
    "format": "{}",
    "exec":"pamixer --get-volume",
    "restart-interval":1,
    "tooltip": false,
    "on-click": "pamixer -t",
    "on-scroll-up": "pamixer -i 5",
    "on-scroll-down": "pamixer -d 5",
    "scroll-step": 5,
    "format-icons": {
      "headphone": "´Çą",
      "hands-free": "´Çą",
      "headset": "´Çą",
      "phone": "´éĽ",
      "portable": "´éĽ",
      "car": "´ć╣",
      "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
    },
    "on-click-right": "pavucontrol -t 1",
    "on-click-middle": "$HOME/.scripts/rofi-bluetooth  & $HOME/.scripts/close_rofi_while_not_focus.sh "
  },
  "pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "´ä░ {volume}%",
    "format-source-muted": "´ä▒ Muted",
    "on-click": "pamixer --default-source -t",
    "on-scroll-up": "pamixer --default-source -i 5",
    "on-scroll-down": "pamixer --default-source -d 5",
    "scroll-step": 5,
    "on-click-right": "pavucontrol -t 2"
  },
  "memory": {
    "interval": 30,
    "format": "{used:0.1f}G/{total:0.1f}G ´âë",
    "on-click": "flatpak run io.missioncenter.MissionCenter"
  },
  "disk": {
    "interval": 30,
    "format": "ˇ░őŐ / {percentage_free}% ",
    "path": "/",
    "on-click": "nautilus -w",
    "on-click-right": "wezterm start ranger $HOME"
  },
  "hyprland/window": {
    "format": "{}",
    "rewrite": {
      "(.*) ÔÇö Mozilla Firefox": "$1"
    },
    "separate-outputs": true,
    "max-length": 35
  },
  "hyprland/submap": {
    "format": "M: {}",
    "max-length": 8,
    "tooltip": false
  },
  "hyprland/workspaces": {
	"format": "{name}",
	"active-only":true,
},
"group/hardware": {
		"orientation": "horizontal",
		"drawer":{
        "transition-duration": 500,
        "children-class": "not-power",
        "transition-left-to-right": false,
    },
		"modules": [
		    "battery",
			"memory",
			"disk",
			"cpu",
			"temperature"
		]
	},
"group/arch": {
		"orientation": "horizontal",
		"drawer":{
        "transition-duration": 500,
        "children-class": "not-power",
        "transition-left-to-right": true,
    },
		"modules": [
		"custom/launcher",
		"custom/reboot",
		"custom/shutdown",
		"custom/hibernate",
		"custom/logout",
		"custom/lock"
		]
	},
  "custom/launcher": {
    "format": " X  ",
    "on-click": "sleep 0.3 ;hyprctl kill",
    "on-click-middle": "killall rofi || $HOME/.config/rofi/launchers/type-7/launcher.sh",
    "on-click-right": "hyprctl dispatch togglefloating",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1"
  },
	"custom/reboot":{
    "format": "ˇ░ťë",
    "on-click-middle": "systemctl reboot",
	},
	"custom/shutdown":{
    "format": "ÔĆ╗",
    "on-click-middle": "systemctl poweroff",
	},
	"custom/hibernate":{
    "format": "ÔĆż",
    "on-click-middle": "systemctl hibernate",
	},
	"custom/logout":{
    "format": "ˇ░Ś╝",
    "on-click-middle": "rm /tmp/$(whoami)/$(echo $WAYLAND_DISPLAY)_env ;rm -rf /tmp/$(whoami)/${WAYLAND_DISPLAY}; hyprctl dispatch exit 0",
	},
	"custom/lock":{
    "format": "ˇ░Źü",
    "on-click": "sleep 1 ; hyprctl dispatch dpms && $HOME/.scripts/idle.sh",
    "on-click-right": "sleep 1 ; hyprctl dispatch dpms && $HOME/.scripts/idle.sh",
    "on-click-middle": "sleep 1 ; hyprctl dispatch dpms && $HOME/.scripts/idle.sh",
	}
}

#workspaces button {
	background: #252733;
	padding: 0 5px;
	color: #c2caea;
	margin-top: 6px;
	margin-left: 8px;
	margin-right: 0px;
	padding-left: 10px;
	padding-right: 10px;
	margin-bottom: 0px;
	border-radius: 10px;
}

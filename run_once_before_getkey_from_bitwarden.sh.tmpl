KEY="${HOME}/.config/chezmoi/key.txt"
if [ ! -f $KEY ] ; then 
    echo {{ (bitwardenFields "item" "chezmoi_agekey.pem").pem_body.value|quote }} > ${KEY}
    chmod 600 ${KEY}
fi
